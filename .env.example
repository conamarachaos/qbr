ANTHROPIC_API_KEY=

# Optional fallback provider
OPENAI_API_KEY=

# Embeddings for the grounded account Q&A chatbot (pgvector retrieval).
# OpenAI text-embedding-3-small (1536-dim). Uses OPENAI_API_KEY above. If that key
# is unset, the app falls back to a deterministic local embedding so the demo still
# works offline (weaker recall).
EMBEDDING_MODEL=text-embedding-3-small

# Persistence (Prisma)
# Inside the aidev task container / CI: use the Postgres container hostname on the shared Docker network.
DATABASE_URL=postgresql://postgres:postgres@qbr-agent-postgres:5432/qbr_agent?schema=public
# When running the app directly on the host: point DATABASE_URL at the published host port instead.
DATABASE_URL_HOST=postgresql://postgres:postgres@localhost:5433/qbr_agent?schema=public

# Auth.js
AUTH_SECRET=replace-me-with-a-long-random-secret
AUTH_URL=http://localhost:3000

# Models
EXTRACTION_MODEL=claude-sonnet-4-6
NARRATIVE_MODEL=claude-opus-4-8
